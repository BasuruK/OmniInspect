{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (make run)",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "${workspaceFolder}/omniview",
            "cwd": "${workspaceFolder}",
            "env": {
                "CGO_CFLAGS": "-I${workspaceFolder}/third_party/odpi/include",
                "CGO_LDFLAGS": "-L${workspaceFolder}/third_party/odpi/lib -lodpi",
                "DYLD_LIBRARY_PATH": "${workspaceFolder}/third_party/odpi/lib:/opt/oracle/instantclient_23_7"
            },
            "preLaunchTask": "make build",
            "console": "integratedTerminal"
        }
    ]
}